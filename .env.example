# KeywordHunter environment template
# Copy this file to .env and set strong credentials before first run.

ADMIN_USER=admin
ADMIN_PASS=admin123
WEB_SECURE_COOKIES=false
SESSION_TTL_HOURS=24
RATE_LIMIT_RPS=12
RATE_LIMIT_BURST=30
LOG_LEVEL=info

# Local calistirmada Tor Browser varsayilani.
# Docker icinde ilk acilista bu deger otomatik tor:9050 olarak migrate edilir.
TOR_PROXY=127.0.0.1:9150
DB_PATH=keywordhunter.db
WEB_ADDR=:8080
LOG_DIR=logs
LOG_LEVEL=info
